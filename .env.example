# Django
DEBUG=True
SECRET_KEY=change-me-to-a-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

# Neon PostgreSQL (formato: postgres://user:password@host/dbname?sslmode=require)
DATABASE_URL=postgres://user:password@ep-example.us-east-2.aws.neon.tech/postflow?sslmode=require

# Criptografia de tokens OAuth (gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
SOCIAL_ENCRYPTION_KEY=your-fernet-key-here

# E-mail (opcional, para notificações)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@postflow.app

# OAuth — Redes Sociais (preencher conforme integração)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
